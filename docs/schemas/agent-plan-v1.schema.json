{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/majiayu000/loom/docs/schemas/agent-plan-v1.schema.json",
  "title": "Loom Agent Plan v1",
  "type": "object",
  "required": [
    "protocol_version",
    "schema_version",
    "plan_id",
    "operation",
    "safe_to_apply",
    "effects",
    "conflicts",
    "risks",
    "required_approvals",
    "recovery",
    "guards"
  ],
  "properties": {
    "protocol_version": { "const": "1.0" },
    "schema_version": { "enum": ["1.0", "1.1", "1.2"] },
    "plan_id": {
      "type": "string",
      "pattern": "^plan_[A-Za-z0-9_]+$"
    },
    "operation": { "enum": ["use", "converge"] },
    "safe_to_apply": { "type": "boolean" },
    "effects": { "type": "array" },
    "conflicts": { "type": "array" },
    "risks": { "type": "array" },
    "required_approvals": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "recovery": {
      "type": "object",
      "required": ["rollback_supported"],
      "properties": {
        "rollback_supported": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "guards": {
      "type": "object",
      "required": ["root", "registry_head", "skill", "source_digest"],
      "properties": {
        "root": { "type": "string" },
        "registry_head": { "type": "string" },
        "skill": { "type": "string" },
        "source_digest": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "agents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "workspace": {
          "type": ["string", "null"]
        },
        "scope": { "type": "string" },
        "method": { "type": "string" },
        "target_root": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "use_args": { "type": "object" },
    "plan_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "selectors": { "type": "object" },
    "source": { "type": "object" },
    "input": { "type": "object" },
    "preflight": { "type": "object" },
    "input_conflicts": {
      "type": "array",
      "items": { "type": "object" }
    },
    "registry": { "type": "object" },
    "projections": { "type": "array" },
    "visibility": { "type": "array" },
    "required_axes": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "requires_digest_confirmation": { "type": "boolean" },
    "execution_enabled": { "type": "boolean" },
    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "schema_version": { "const": "1.0" } },
        "required": ["schema_version"]
      },
      "then": { "properties": { "operation": { "const": "use" } } }
    },
    {
      "if": {
        "properties": { "operation": { "const": "converge" } },
        "required": ["operation"]
      },
      "then": {
        "properties": {
          "schema_version": { "const": "1.2" },
          "requires_digest_confirmation": { "const": true },
          "execution_enabled": { "const": true }
        },
        "required": [
          "plan_digest",
          "selectors",
          "source",
          "input",
          "preflight",
          "input_conflicts",
          "registry",
          "projections",
          "visibility",
          "required_axes",
          "requires_digest_confirmation",
          "execution_enabled"
        ]
      }
    }
  ],
  "additionalProperties": true
}
