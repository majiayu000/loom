{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/majiayu000/loom/docs/schemas/agent-adapter-v2.schema.json",
  "title": "Loom Agent Adapter v2",
  "type": "object",
  "required": [
    "adapter_api",
    "id",
    "supported_scopes",
    "projection_methods",
    "skill_entrypoint",
    "capabilities",
    "discovery_roots",
    "visibility",
    "reload"
  ],
  "properties": {
    "adapter_api": { "const": "2" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,64}$"
    },
    "supported_scopes": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["user", "project"] },
      "uniqueItems": true
    },
    "projection_methods": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["copy", "symlink", "materialize"] },
      "uniqueItems": true
    },
    "skill_entrypoint": { "const": "SKILL.md" },
    "capabilities": {
      "type": "object",
      "properties": {
        "automatic_discovery": { "type": "boolean" },
        "explicit_invocation": { "type": "boolean" },
        "reload_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "discovery_roots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scope", "role"],
        "oneOf": [
          { "required": ["path"] },
          { "required": ["path_template"] }
        ],
        "properties": {
          "scope": { "enum": ["user", "project"] },
          "path": { "type": "string", "minLength": 1 },
          "path_template": { "type": "string", "minLength": 1 },
          "role": {
            "enum": [
              "preferred-cross-client",
              "project-cross-client",
              "legacy",
              "legacy-default",
              "env-override",
              "manual"
            ]
          },
          "source_env_var": { "type": "string", "minLength": 1 },
          "priority": { "type": "integer", "minimum": 0 },
          "scan_eligible": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "visibility": {
      "type": "object",
      "properties": {
        "follows_symlink_dirs": { "type": "boolean" },
        "identity": {
          "enum": [
            "canonical-skill-md-path",
            "runtime-skill-md-path",
            "directory-path",
            "adapter-defined"
          ]
        },
        "identity_by_projection_method": {
          "type": "object",
          "additionalProperties": {
            "enum": [
              "canonical-skill-md-path",
              "runtime-skill-md-path",
              "directory-path",
              "adapter-defined"
            ]
          }
        },
        "config_file": { "type": "string", "minLength": 1 },
        "disable_rules": {
          "type": "array",
          "items": { "enum": ["skills.config.path", "adapter-defined"] },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "reload": {
      "type": "object",
      "required": ["strategy", "hot_reload"],
      "properties": {
        "strategy": {
          "enum": [
            "no-reload-required",
            "new-session-recommended",
            "restart-required",
            "unknown"
          ]
        },
        "hot_reload": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
