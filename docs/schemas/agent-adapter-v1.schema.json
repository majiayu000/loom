{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/majiayu000/loom/docs/schemas/agent-adapter-v1.schema.json",
  "title": "Loom Agent Adapter v1",
  "type": "object",
  "required": [
    "adapter_api",
    "id",
    "supported_scopes",
    "projection_methods",
    "skill_entrypoint",
    "capabilities"
  ],
  "properties": {
    "adapter_api": { "const": "1" },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_-]{1,64}$"
    },
    "supported_scopes": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["user", "project"] },
      "uniqueItems": true
    },
    "projection_methods": {
      "type": "array",
      "minItems": 1,
      "items": { "enum": ["copy", "symlink", "materialize"] },
      "uniqueItems": true
    },
    "skill_entrypoint": { "const": "SKILL.md" },
    "capabilities": {
      "type": "object",
      "properties": {
        "automatic_discovery": { "type": "boolean" },
        "explicit_invocation": { "type": "boolean" },
        "reload_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "default_skill_dirs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
