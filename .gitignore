# Loom tool repo should not keep runtime registry state.
/state/
# Local Claude Code session worktrees; shared .claude config remains trackable.
/.claude/worktrees/
/state/locks/
/state/panel.log
/state/targets.json
/state/pending_ops.jsonl
panel/node_modules/
panel/dist/
target/
.omx/
# Ignore mutable registry content in the tool checkout, but ship the scoped
# first-party Agent Skill used by release archives and installation docs.
/skills/*
!/skills/loom-registry/
!/skills/loom-registry/**
